{
  "name": "aart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint",
    "deploy": "npx vercel --prod",
    "deploy:preview": "npx vercel",
    "deploy:link": "npx vercel link",
    "db:start:local": "supabase start",
    "db:stop:local": "supabase stop",
    "db:status:local": "supabase status",
    "db:migrate:local": "supabase migration up",
    "db:reset:local": "supabase db reset",
    "db:migrations:verify": "node scripts/migration-integrity.js verify",
    "db:migrations:snapshot": "node scripts/migration-integrity.js snapshot",
    "db:push:local:raw": "supabase db push --local",
    "db:push:prod:raw": "bash -lc 'set -a && source .env.prod && set +a && supabase db push --db-url \"$SUPABASE_DB_URL\"'",
    "db:push:local": "npm run db:migrations:verify && npm run db:push:local:raw && npm run db:migrations:snapshot",
    "db:push:prod": "npm run db:migrations:verify && npm run db:push:prod:raw && npm run db:migrations:snapshot",
    "db:push:all": "npm run db:push:local && npm run db:push:prod",
    "db:pull:prod": "bash -lc 'set -a && source .env.prod && set +a && supabase db pull --db-url \"$SUPABASE_DB_URL\"'",
    "db:start": "npm run db:start:local",
    "db:stop": "npm run db:stop:local",
    "db:status": "npm run db:status:local",
    "db:reset": "npm run db:reset:local",
    "db:push": "npm run db:push:prod",
    "db:pull": "npm run db:pull:prod",
    "db:migration:new": "supabase migration new",
    "db:backup:prod": "bash -lc 'set -a && source .env.prod && set +a && bash scripts/backup-prod.sh'",
    "db:backup:inspect": "bash scripts/inspect-backup.sh"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/nextjs": "^10.3.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "popular-english-words": "^1.0.2",
    "storybook": "^10.3.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
